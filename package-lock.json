{
  "name": "wlearn",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@wlearn/automl": {
      "resolved": "packages/automl",
      "link": true
    },
    "node_modules/@wlearn/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@wlearn/ensemble": {
      "resolved": "packages/ensemble",
      "link": true
    },
    "node_modules/@wlearn/types": {
      "resolved": "packages/types",
      "link": true
    },
    "packages/automl": {
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@wlearn/core": "0.1.0",
        "@wlearn/ensemble": "0.1.0",
        "@wlearn/types": "0.1.0"
      }
    },
    "packages/core": {
      "name": "@wlearn/core",
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@wlearn/types": "0.1.0"
      }
    },
    "packages/ensemble": {
      "version": "0.1.0",
      "license": "MIT",
      "dependencies": {
        "@wlearn/core": "0.1.0",
        "@wlearn/types": "0.1.0"
      }
    },
    "packages/types": {
      "name": "@wlearn/types",
      "version": "0.1.0",
      "license": "MIT"
    }
  }
}
