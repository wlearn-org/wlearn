{
  "name": "@wlearn/automl",
  "version": "0.1.0",
  "description": "AutoML engine for wlearn: search space sampling, random search, successive halving, ensemble construction",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "dist/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "dependencies": {
    "@wlearn/core": "0.1.0",
    "@wlearn/ensemble": "0.1.0",
    "@wlearn/types": "0.1.0"
  },
  "scripts": {
    "test": "node --test test/*.js",
    "build:browser": "bash scripts/build-browser.sh",
    "prepack": "node scripts/prepack.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "wlearn",
    "automl",
    "machine-learning",
    "hyperparameter-optimization"
  ],
  "author": "Anton Zemlyansky",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlearn-org/wlearn.git",
    "directory": "packages/automl"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "esbuild": "^0.27.3",
    "playwright": "^1.58.2"
  }
}
