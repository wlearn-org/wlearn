{
  "name": "@wlearn/sdk",
  "version": "0.1.0",
  "description": "Convenience barrel: re-exports all wlearn model classes, automl, ensemble, pipeline, and core utilities",
  "type": "commonjs",
  "main": "index.js",
  "exports": {
    ".": {
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "dependencies": {
    "@wlearn/core": "0.1.0",
    "@wlearn/automl": "0.1.0",
    "@wlearn/ensemble": "0.1.0",
    "@wlearn/liblinear": "0.1.0",
    "@wlearn/libsvm": "0.1.0",
    "@wlearn/xgboost": "0.1.1",
    "@wlearn/lightgbm": "0.1.0",
    "@wlearn/nanoflann": "0.1.0",
    "@wlearn/ebm": "0.1.0",
    "@wlearn/xlearn": "0.1.0",
    "@wlearn/stochtree": "0.1.0",
    "@wlearn/tsetlin": "0.1.0",
    "@wlearn/nn": "0.1.0",
    "@wlearn/rf": "0.1.0",
    "@wlearn/gam": "0.1.0",
    "@wlearn/cluster": "0.1.0"
  },
  "peerDependencies": {
    "@wlearn/mitra": "0.1.0"
  },
  "peerDependenciesMeta": {
    "@wlearn/mitra": { "optional": true }
  },
  "scripts": {
    "test": "node --test test/*.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Anton Zemlyansky",
  "license": "Apache-2.0"
}
